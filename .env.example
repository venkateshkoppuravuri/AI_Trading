# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Alpaca Paper Trading ──────────────────────────────────
ALPACA_API_KEY=your_api_key_here
ALPACA_API_SECRET=your_api_secret_here

# Leave as-is for paper trading.
# Change to https://api.alpaca.markets/v2 for live trading.
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2

# ── Telegram Alerts (Week 1) ──────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → copy token
# 2. Send any message to your new bot, then run:
#    python -c "from trading.alerts.telegram import TelegramBot; TelegramBot.get_chat_id()"
# 3. Paste the Chat ID below
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── Finnhub (Week 1 — News Sentiment + Analyst Ratings) ───
# Free key at https://finnhub.io → Sign up → API Keys tab
# 60 calls/minute on free tier — more than enough
FINNHUB_API_KEY=your_finnhub_key_here

# ── FRED (Week 1 — Macro Data) ────────────────────────────
# Optional — many series work without a key.
# Free key at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key_here

# ── Anthropic / Claude (Week 6 — LLM Reasoning) ───────────
# Get key at https://console.anthropic.com → API Keys
# Used to approve/reject LightGBM picks before placing orders
# Without this key: all LightGBM picks are auto-approved (bot still works)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Timezone (Cloud Deployment) ───────────────────────────
# Set to US/Eastern so the scheduler fires at the right time.
# Railway / Render containers default to UTC.
TZ=America/New_York
